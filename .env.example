# Supabase Postgres (Prisma) - Project Settings -> Database
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].supabase.co:5432/postgres"

# Demo showcase user (optional — `npm run db:seed`). Sign in after seed to explore sample data.
# DEMO_SEED_EMAIL="garden-demo@example.soilmates"
# DEMO_SEED_PASSWORD="DemoGarden2026!"
#
# Match the seeded demo for the login page “Use demo account” button (portfolio link: /login?pf_src=soilmates).
# NEXT_PUBLIC_DEMO_LOGIN_EMAIL="garden-demo@example.soilmates"
# NEXT_PUBLIC_DEMO_LOGIN_PASSWORD="DemoGarden2026!"

# NextAuth (Google OAuth + email/password credentials stored in Postgres via Prisma)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Optional; trustHost helps local dev without AUTH_URL
AUTH_URL="http://localhost:3000"

# Public site URL for Open Graph / metadata (production: https://your-domain.com)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google

# Supabase Storage (server-only) - private plant photos & signed URLs
# Project Settings -> API: Project URL + service_role key (never expose to client)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# Create a private bucket named `plant-images` (no public access). Uploads use the service role.

TREFLE_API_KEY=""

# NVIDIA integrate API (OpenAI-compatible chat completions). Server-side only.
# https://build.nvidia.com/ — create an API key (nvapi-…).
NVIDIA_API_KEY=""
# Optional; default shown below.
# NVIDIA_CHAT_MODEL="google/gemma-3n-e4b-it"
# NVIDIA_ASSISTANT_MAX_TOKENS="1200"
# NVIDIA_DIAGNOSIS_MAX_TOKENS="2048"
# Optional: use a different model for diagnosis-only calls.
# NVIDIA_DIAGNOSIS_MODEL=""

# Web Push (VAPID) — generate keys: npx web-push generate-vapid-keys
# Public key is exposed to the client (NEXT_PUBLIC_).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# mailto: or https: URL identifying the sender (Web Push spec).
# VAPID_SUBJECT="mailto:you@example.com"

# Optional: protect /api/cron/reminder-push (Authorization: Bearer …)
# Schedule reminder delivery with an external cron (e.g. https://console.cron-job.org/jobs ):
#   URL: https://<your-domain>/api/cron/reminder-push
#   Method: GET
#   Header: Authorization: Bearer <CRON_SECRET> (when CRON_SECRET is set)
# Suggested schedule: every 15 minutes.
# CRON_SECRET=""

# Feature flags (default: enabled). Set to "false" to disable in production.
# NEXT_PUBLIC_FEATURE_AI_ASSISTANT="true"
# NEXT_PUBLIC_FEATURE_AI_DIAGNOSIS="true"
# NEXT_PUBLIC_FEATURE_PUSH="true"
# NEXT_PUBLIC_FEATURE_OFFLINE_SYNC="true"

# Optional: NVIDIA request timeout (ms); default 90000
# NVIDIA_FETCH_TIMEOUT_MS="90000"
